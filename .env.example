# Application metadata.
APP_TITLE=new-api-log-statistics
APP_VERSION=0.2.0

# Runtime mode.
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=18080
NGINX_PORT=18090
TZ=Asia/Shanghai
LOG_LEVEL=INFO

# Query/cache tuning.
QUERY_CACHE_TTL=300
DB_POOL_SIZE=4
REQUEST_TIMEOUT_SECONDS=5
SLOW_QUERY_THRESHOLD_MS=250

# Data source behavior.
ALLOW_REMOTE_DB=true
REDIS_URL=
ENABLE_LOCAL_IMPORT=false
STARTUP_VALIDATE_SOURCES=true
LOCAL_IMPORT_SCAN_ROOTS=/app
LOCAL_IMPORT_MAX_DEPTH=3
SOURCE_CONFIG_PATH=/app/config/sources.yml

# Optional login guard. Set AUTH_ENABLED=true and provide a password to require login.
AUTH_ENABLED=false
AUTH_USERNAME=admin
AUTH_PASSWORD=
AUTH_SESSION_SECRET=change-this-in-production
AUTH_SESSION_COOKIE=new_api_log_statistics_session
AUTH_SESSION_MAX_AGE=43200
AUTH_COOKIE_SECURE=false
AUTH_ALLOW_BASIC=true
AUTH_PUBLIC_HEALTH=true

# Log output paths inside container.
APP_LOG_PATH=/app/runtime/app.log
ACCESS_LOG_PATH=/app/runtime/access.log
AUDIT_LOG_PATH=/app/runtime/audit.log
